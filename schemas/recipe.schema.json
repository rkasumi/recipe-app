{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:recipe-app:schemas:recipe",
  "title": "RecipeDocument",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "servings",
    "source_refs",
    "ingredients",
    "steps",
    "flow",
    "audit"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "servings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "ingredients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ingredientGroup"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "flow": {
      "$ref": "#/$defs/flow"
    },
    "audit": {
      "$ref": "#/$defs/audit"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "type": {
          "type": "string",
          "enum": ["youtube_description", "youtube_transcript", "macwhisper_transcript", "book_excerpt", "article_excerpt", "manual_note", "other"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "ingredientGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "items"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ingredient"
          }
        },
        "note": {
          "type": "string"
        }
      }
    },
    "ingredient": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "quantity": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "source_ref_id": {
          "type": "string"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "instruction"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "ingredients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "duration": {
          "type": "string"
        },
        "heat": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "source_ref_id": {
          "type": "string"
        }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "nodes", "edges"],
      "properties": {
        "layout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["direction"],
          "properties": {
            "direction": {
              "type": "string",
              "enum": ["LR", "TB"]
            },
            "lane_labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/flowNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flowEdge"
          }
        }
      }
    },
    "flowNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "lane", "rank", "shape"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "kind": {
          "type": "string",
          "enum": ["ingredient_group", "action", "note", "wait", "combine", "finish"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "type": "string",
          "minLength": 1
        },
        "rank": {
          "type": "integer",
          "minimum": 0
        },
        "shape": {
          "type": "string",
          "enum": ["rectangle", "pill", "diamond", "circle"]
        },
        "step_id": {
          "type": "string"
        },
        "ingredients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layout_override": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          }
        }
      }
    },
    "flowEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["needs_review", "warnings", "source_fidelity_notes", "missing_information"],
      "properties": {
        "needs_review": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_fidelity_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_information": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "generated_by": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
